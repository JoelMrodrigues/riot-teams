# Modèle de configuration — copie ce fichier en `.env` et remplis les valeurs.
# Obtiens tes clés sur https://developer.riotgames.com
# NE JAMAIS committer le fichier `.env` (déjà ignoré par git).

# Clé de production (gérée via Railway en prod).
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Clé de test (développement local).
RIOT_API_KEY_TEST=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Quelle clé utiliser côté serveur: "test" (défaut) ou "prod".
RIOT_KEY_MODE=test

# Plateforme par défaut (euw1, na1, kr, eun1, br1, jp1, ...).
RIOT_DEFAULT_PLATFORM=euw1

# Port du serveur proxy (Railway le fournit automatiquement en prod).
PORT=3001

# Origine autorisée pour CORS (dev). En prod single-origin Railway, inutile.
WEB_ORIGIN=http://localhost:5173
